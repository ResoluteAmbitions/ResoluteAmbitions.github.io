---
import Base from '../layouts/Base.astro';
import Donorbox from '../components/Donorbox.astro';

// Set this to your Donorbox campaign slug once the account is approved.
// Example: 'resolute-ambitions-general-fund'
const DONORBOX_SLUG: string | undefined = undefined;
---
<Base title="Donate" description="Support Resolute Ambitions and help fund the next generation of U.S. military officers.">
  <section class="page-intro">
    <div class="container">
      <div class="eyebrow dark">Donate</div>
      <h1>Fund a future officer.</h1>
      <p class="lede">
        Your contribution pays tuition, fees, books, and required testing for candidates pursuing a U.S. military officer commission. We run lean — volunteer-led, minimal overhead, funds disbursed directly to accredited institutions.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="donate-wrap">
        <div>
          <h2 style="margin-top: 0;">Where your gift goes</h2>
          <ul class="checked">
            <li>Tuition and mandatory fees at accredited institutions</li>
            <li>Books and required educational materials</li>
            <li>Room and board for scholarship recipients</li>
            <li>Standardized testing and certification fees</li>
          </ul>
          <p>
            Scholarship funds are paid directly to schools on each recipient's behalf — never to individuals — to ensure exclusive educational use. Enrollment and academic progress are verified before every disbursement.
          </p>

          <div class="disclosure">
            <strong>501(c)(3) status: pending.</strong> Resolute Ambitions has filed for federal tax-exempt recognition. Contributions made now will be retroactively tax-deductible to our filing date upon IRS approval. Please consult your tax advisor for guidance specific to your situation.
          </div>

          <p style="margin-top: 2rem;">
            Prefer to give another way, sponsor a scholarship, or talk to us about a corporate match?
            <a href="mailto:info@resoluteambitions.com">Email info@resoluteambitions.com</a>.
          </p>
        </div>

        <aside>
          <div class="donate-embed">
            <Donorbox campaignSlug={DONORBOX_SLUG} />
          </div>
        </aside>
      </div>
    </div>
  </section>
</Base>
