---
import Base from '../layouts/Base.astro';
---
<Base title="Contact" description="Get in touch with Resolute Ambitions.">
  <section class="page-intro">
    <div class="container">
      <div class="eyebrow dark">Contact</div>
      <h1>Get in touch.</h1>
      <p class="lede">
        Whether you want to give, apply, partner, or just understand the mission better — we'd like to hear from you.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <h2>Email</h2>
      <p>
        General inquiries, scholarship questions, partnerships, and press:
        <br />
        <a href="mailto:info@resoluteambitions.com">info@resoluteambitions.com</a>
      </p>

      <h2>For prospective applicants</h2>
      <p>
        Applications are not yet open. Email us to be added to a notification list and we will send program details and timelines once the inaugural cycle is funded.
      </p>

      <h2>For donors and sponsors</h2>
      <p>
        Contributions are accepted on our <a href="/donate">donate page</a>. For named scholarships, corporate sponsorships, or matching gifts, email <a href="mailto:info@resoluteambitions.com">info@resoluteambitions.com</a>.
      </p>

      <h2>For board service and volunteers</h2>
      <p>
        We are actively building our board and selection committee — particularly educators, military veterans, and financial professionals. If that's you, we'd like to talk.
      </p>
    </div>
  </section>
</Base>
